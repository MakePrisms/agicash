# Agicash CLI runtime overrides
# Copy this file to ~/.agicash/.env for a global install,
# or to ./.env for project-local overrides.

# Published releases can bake these public values in at build time.
# Set them here only when you want to override the bundled defaults.
OPENSECRET_CLIENT_ID=
OPENSECRET_API_URL=

# Supabase cloud sync (same project as the web app)
SUPABASE_URL=
SUPABASE_ANON_KEY=
