# Agicash CLI Configuration
# Copy to .env and fill in your values

# Required for send/pay/receive — generate with:
# bun -e "import{generateMnemonic}from'@scure/bip39';import{wordlist}from'@scure/bip39/wordlists/english';console.log(generateMnemonic(wordlist))"
AGICASH_MNEMONIC=

# OpenSecret auth (required for: auth login, auth signup, auth status, cloud sync)
OPENSECRET_CLIENT_ID=
OPENSECRET_API_URL=https://preview.opensecret.cloud

# Supabase (required for cloud sync — same project as the web app)
SUPABASE_URL=
SUPABASE_ANON_KEY=
