{
  "name": "@agicash/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Bun-based Agicash CLI for Cashu ecash and Lightning payments",
  "type": "module",
  "bin": {
    "agicash": "./src/main.ts"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --compile --outfile=agicash",
    "build:release": "bun run src/build-release.ts",
    "publish:dry-run": "bun run build:release && bun publish --cwd ./dist/npm --dry-run",
    "test": "bun test",
    "mcp": "bun run src/mcp/server.ts"
  },
  "dependencies": {
    "@agicash/opensecret-sdk": "MakePrisms/OpenSecret-SDK#dist",
    "@agicash/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "5.9.3"
  }
}
