{
  "framework": "react-router",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Document-Policy",
          "value": "js-profiling"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/publish-zap-receipts",
      "schedule": "* * * * *"
    }
  ]
}
