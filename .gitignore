# Devenv
.devenv*
devenv.local.nix

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml

# IDEs and editors
/.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

node_modules

/.cache
/build
.env
.vercel
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

.DS_Store

# Claude Code
.claude/settings.local.json
.claude/worktrees/

.react-router/

# Local SSL certificates
/certs/*
!/certs/ci-localhost-cert.pem
!/certs/ci-localhost-key.pem

# Breez Spark SDK cache data 
.spark-data/

# Rust
/target
/crates/target
/crates/**/pkg
# Per-machine cargo cache config (shared CARGO_TARGET_DIR + sccache wrapper).
# Generated locally for cross-worktree build caching; absolute macOS paths
# inside break CI on Linux runners. See feedback_dev_loop_cache memory note.
/crates/.cargo/

# sccache local cache directory (devenv.nix RUSTC_WRAPPER).
/.sccache

# iOS / Swift bindings
/bindings/swift/rust/target
/bindings/swift/build
/bindings/swift/Sources
/ios/**/build
/ios/**/*.xcodeproj
/ios/**/DerivedData
