# agicash rust workspace — local-dev environment.
#
# Copy to `.env` (gitignored) and edit the secrets section. The flake's
# default shell already exports sane defaults for everything below
# pointing at the local opensecret + Supabase stack, so the .env file
# only needs to contain the values you want to override OR the secrets
# (anon key / service-role key) that get regenerated when you run
# `supabase start` against a fresh local instance.
#
# After editing .env: `direnv reload` (or `cd .` to re-enter the dir)
# reloads the shell with your overrides in place.

# ===== OpenSecret enclave (auth) =============================================
# Used by: agicash-auth-opensecret, agicash-cli, agicash-web-leptos.
# `from_env()` in `crates/agicash-auth-opensecret/src/config.rs`.
# The default points at the local enclave run via
# `cd ~/opensecret && cargo run` (per memory project_opensecret_local_stack.md).
OPENSECRET_BASE_URL=http://127.0.0.1:3999
# Pre-seeded Maple project UUID in the local opensecret postgres.
OPENSECRET_CLIENT_ID=ba5a14b5-d915-47b1-b7b1-afda52bc5fc6

# ===== Supabase (storage) ====================================================
# Used by: agicash-storage-supabase, agicash-cli, agicash-web-leptos.
# `from_env()` in `crates/agicash-storage-supabase/src/config.rs` reads
# SUPABASE_URL first, falling back to VITE_SUPABASE_URL for backwards-
# compat with the React-era .env. Same for SUPABASE_ANON_KEY.
SUPABASE_URL=https://127.0.0.1:54321

# Anon JWT — regenerated by `supabase start`. Copy from `supabase status`.
# Default is the well-known supabase local-dev anon key (safe to commit
# since it's the published default; replace if your local instance has
# regenerated it).
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service-role JWT — required by integration tests that bypass RLS
# (`crates/agicash-storage-supabase/tests/*`). Copy from `supabase status`.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# HS256 secret aligned across opensecret + supabase so the JWT chain
# works (per memory reference_jwt_chain_recipe.md). Must match the
# `JWT_SECRET` in your local opensecret-postgres and the
# `auth.jwt_secret` setting in supabase/config.toml.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ===== Local SSL cert paths (used by supabase/config.toml) ====================
# The flake auto-generates these via `generate-ssl-cert` if missing.
# `supabase/config.toml` reads them with `env(SELF_SIGNED_CERT_*)` and
# resolves the value relative to the supabase/ directory — hence `../certs/`.
SELF_SIGNED_CERT_PATH=../certs/localhost-cert.pem
SELF_SIGNED_CERT_KEY_PATH=../certs/localhost-key.pem

# ===== Optional rust-side overrides ==========================================

# Override the OS-keyring service name used by agicash-cli session
# storage. Default is the crate const DEFAULT_SERVICE.
# AGICASH_KEYRING_SERVICE=agicash

# Path to an encrypted session file (CLI alternative to OS keyring).
# Currently stubbed in agicash-cli/src/composition.rs; setting this
# causes the CLI to fall back to in-memory storage with a warning.
# AGICASH_SESSION_FILE=./.agicash-session

# Override the test mint URL used by integration tests in
# crates/agicash-cashu/src/provider.rs. Default is a well-known testnet
# mint when unset; provide your own for offline runs.
# AGICASH_TEST_MINT_URL=https://testmint.agicash.example
