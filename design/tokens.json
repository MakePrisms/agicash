{
  "version": "1.0.0",
  "source": {
    "repo": "agicash",
    "branch": "chore/design-tokens",
    "extracted_from_commit": "5751be2e",
    "tailwind_version": "4.1.18",
    "notes": "Values extracted verbatim from app/tailwind.css and app/components/ui/*.tsx. Anything not declared explicitly in the codebase falls back to Tailwind v4 defaults; those defaults are reproduced inline below so iOS/Android do not need to consult the Tailwind source."
  },

  "fonts": {
    "primary": {
      "family": "Kode Mono",
      "css_var": "--font-primary",
      "source": "google-fonts",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400..700&family=Teko:wght@300..700&display=swap",
      "weights": [400, 500, 600, 700],
      "fallback_css": "monospace",
      "fallback_platform": {
        "ios": "Menlo, monospace",
        "android": "monospace",
        "system": "ui-monospace, SFMono-Regular, Menlo, monospace"
      },
      "usage": "Default UI text. Applied via font-primary utility."
    },
    "numeric": {
      "family": "Teko",
      "css_var": "--font-numeric",
      "source": "google-fonts",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400..700&family=Teko:wght@300..700&display=swap",
      "weights": [300, 400, 500, 600, 700],
      "fallback_css": "sans-serif",
      "usage": "All monetary amounts via font-numeric utility. See app/components/money-display.tsx."
    }
  },

  "type_scale": {
    "comment": "Tailwind v4 default scale (rem-based, 16px root). The app uses these via utility classes text-{name}. Custom: text-2xs at 0.625rem.",
    "2xs": {
      "size_rem": 0.625,
      "size_px": 10,
      "line_height_rem": 1.0,
      "line_height_px": 16,
      "source": "custom"
    },
    "xs": {
      "size_rem": 0.75,
      "size_px": 12,
      "line_height_rem": 1.0,
      "line_height_px": 16
    },
    "sm": {
      "size_rem": 0.875,
      "size_px": 14,
      "line_height_rem": 1.25,
      "line_height_px": 20
    },
    "base": {
      "size_rem": 1.0,
      "size_px": 16,
      "line_height_rem": 1.5,
      "line_height_px": 24
    },
    "lg": {
      "size_rem": 1.125,
      "size_px": 18,
      "line_height_rem": 1.75,
      "line_height_px": 28
    },
    "xl": {
      "size_rem": 1.25,
      "size_px": 20,
      "line_height_rem": 1.75,
      "line_height_px": 28
    },
    "2xl": {
      "size_rem": 1.5,
      "size_px": 24,
      "line_height_rem": 2.0,
      "line_height_px": 32
    },
    "3xl": {
      "size_rem": 1.875,
      "size_px": 30,
      "line_height_rem": 2.25,
      "line_height_px": 36
    },
    "4xl": {
      "size_rem": 2.25,
      "size_px": 36,
      "line_height_rem": 2.5,
      "line_height_px": 40
    },
    "5xl": {
      "size_rem": 3.0,
      "size_px": 48,
      "line_height_rem": 1.0,
      "line_height_px": 48
    },
    "6xl": {
      "size_rem": 3.75,
      "size_px": 60,
      "line_height_rem": 1.0,
      "line_height_px": 60
    },
    "7xl": {
      "size_rem": 4.5,
      "size_px": 72,
      "line_height_rem": 1.0,
      "line_height_px": 72
    }
  },

  "money_display_sizes": {
    "comment": "Hard-coded sizes for currency symbol + value in app/components/money-display.tsx",
    "xs": {
      "symbol_rem": 1.1,
      "value_text": "xl",
      "value_px": 20,
      "weight": 600
    },
    "sm": {
      "symbol_rem": 1.33,
      "value_text": "2xl",
      "value_px": 24,
      "weight": 600
    },
    "md": {
      "symbol_rem": 2.85,
      "value_text": "5xl",
      "value_px": 48,
      "weight": 700
    },
    "lg": {
      "symbol_rem": 3.45,
      "value_text": "6xl",
      "value_px": 60,
      "weight": 700
    }
  },

  "font_weights": {
    "comment": "Tailwind v4 defaults. App uses font-medium, font-semibold, font-bold predominantly.",
    "thin": 100,
    "extralight": 200,
    "light": 300,
    "normal": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700,
    "extrabold": 800,
    "black": 900
  },

  "colors": {
    "format": "hsl",
    "comment": "All values verbatim from app/tailwind.css. Currency themes (usd/btc) replace a subset of root tokens, listed under overrides.",

    "themes": {
      "light": {
        "background": "hsl(0 0% 100%)",
        "foreground": "hsl(0 0% 3.9%)",
        "card": "hsl(0 0% 100%)",
        "card_foreground": "hsl(0 0% 98%)",
        "popover": "hsl(0 0% 100%)",
        "popover_foreground": "hsl(0 0% 3.9%)",
        "primary": "hsl(0 0% 9%)",
        "primary_foreground": "hsl(0 0% 98%)",
        "secondary": "hsl(0 0% 96.1%)",
        "secondary_foreground": "hsl(0 0% 9%)",
        "muted": "hsl(0 0% 96.1%)",
        "muted_foreground": "hsl(0 0% 45.1%)",
        "accent": "hsl(0 0% 96.1%)",
        "accent_foreground": "hsl(0 0% 9%)",
        "destructive": "hsl(0 84.2% 60.2%)",
        "destructive_foreground": "hsl(0 0% 98%)",
        "border": "hsl(0 0% 89.8%)",
        "input": "hsl(0 0% 89.8%)",
        "ring": "hsl(0 0% 83.1%)",
        "chart_1": "hsl(12 76% 61%)",
        "chart_2": "hsl(173 58% 39%)",
        "chart_3": "hsl(197 37% 24%)",
        "chart_4": "hsl(43 74% 66%)",
        "chart_5": "hsl(27 87% 67%)"
      },

      "dark": {
        "background": "hsl(0 0% 3.9%)",
        "foreground": "hsl(0 0% 98%)",
        "card": "hsl(0 0% 3.9%)",
        "card_foreground": "hsl(0 0% 98%)",
        "popover": "hsl(0 0% 3.9%)",
        "popover_foreground": "hsl(0 0% 98%)",
        "primary": "hsl(202 13% 13%)",
        "primary_foreground": "hsl(0 0% 98%)",
        "secondary": "hsl(0 0% 14.9%)",
        "secondary_foreground": "hsl(0 0% 98%)",
        "muted": "hsl(0 0% 12%)",
        "muted_foreground": "hsl(0 0% 63.9%)",
        "accent": "hsl(0 0% 14.9%)",
        "accent_foreground": "hsl(0 0% 98%)",
        "destructive": "hsl(0 62.8% 30.6%)",
        "destructive_foreground": "hsl(0 0% 98%)",
        "border": "hsl(0 0% 14.9%)",
        "input": "hsl(0 0% 14.9%)",
        "ring": "hsl(0 0% 83.1%)",
        "chart_1": "hsl(220 70% 50%)",
        "chart_2": "hsl(160 60% 45%)",
        "chart_3": "hsl(30 80% 55%)",
        "chart_4": "hsl(280 65% 60%)",
        "chart_5": "hsl(340 75% 55%)"
      },

      "usd": {
        "_inherits": "light",
        "_comment": "Currency theme — overrides applied on top of light theme via .usd class on <html>. All other tokens stay at light values.",
        "background": "hsl(178 100% 15%)",
        "foreground": "hsl(178 30% 90%)",
        "primary": "hsl(177 42% 26%)",
        "primary_foreground": "hsl(178 30% 90%)",
        "muted": "hsl(178 100% 14%)",
        "muted_foreground": "hsl(178 30% 81%)",
        "border": "hsl(178 100% 21%)",
        "card": "hsl(178 100% 14%)"
      },

      "btc": {
        "_inherits": "light",
        "_comment": "Currency theme — overrides applied on top of light theme via .btc class on <html>. All other tokens stay at light values.",
        "background": "hsl(217 68% 35%)",
        "foreground": "hsl(217 30% 90%)",
        "primary": "hsl(219 44% 45%)",
        "primary_foreground": "hsl(217 30% 90%)",
        "muted": "hsl(217 68% 38%)",
        "muted_foreground": "hsl(217 30% 85%)",
        "border": "hsl(217 70% 45%)",
        "card": "hsl(217 68% 38%)"
      }
    },

    "semantic_aliases": {
      "success_comment": "No explicit success color defined in the design system; the codebase uses ad-hoc green utilities (e.g. text-green-500) for success states. Treat success as an unsolved token if iOS/Android need it — add deliberately rather than guess.",
      "destructive": "themes.*.destructive",
      "warning_comment": "No explicit warning token; not currently used."
    },

    "theme_scoping_mechanism": {
      "description": "Two independent axes, applied as classes on the <html> root element.",
      "axis_currency": ["usd", "btc"],
      "axis_color_mode": ["light", "dark"],
      "rules": [
        "Color-mode 'dark' takes precedence: when .dark is present alongside .usd or .btc, the .dark variables apply because .dark appears later in the CSS cascade (see app/tailwind.css lines 47-89).",
        "Persisted in cookies for SSR (no localStorage flash). See app/features/theme/theme-cookies.server.ts."
      ]
    }
  },

  "spacing": {
    "comment": "Tailwind v4 default scale. Base unit = 0.25rem = 4px. Values are 0.25rem * N. App uses 0, 0.5, 1, 1.5, 2, 3, 4, 6, 8 most heavily (see component classes).",
    "unit_rem": 0.25,
    "unit_px": 4,
    "scale": {
      "0": 0,
      "px": 1,
      "0.5": 2,
      "1": 4,
      "1.5": 6,
      "2": 8,
      "2.5": 10,
      "3": 12,
      "3.5": 14,
      "4": 16,
      "5": 20,
      "6": 24,
      "7": 28,
      "8": 32,
      "9": 36,
      "10": 40,
      "11": 44,
      "12": 48,
      "14": 56,
      "16": 64,
      "20": 80,
      "24": 96,
      "32": 128
    }
  },

  "radius": {
    "comment": "Tailwind v4 names. Note: shadcn v4 uses rounded-xs (the v4 name) where v3 used rounded-sm. Custom --radius token in app/tailwind.css line 30 = 0.5rem = 8px (same as rounded-lg). App heavily uses rounded-md (buttons, inputs) and rounded-lg (cards). Drawers use 10px (rounded-t-[10px]).",
    "base_token": { "rem": 0.5, "px": 8 },
    "scale": {
      "none": 0,
      "xs": 2,
      "sm": 4,
      "md": 6,
      "lg": 8,
      "xl": 12,
      "2xl": 16,
      "3xl": 24,
      "drawer_top": 10,
      "full": 9999
    }
  },

  "motion": {
    "comment": "The app uses CSS keyframes + tailwindcss-animate + vaul for drawers + the browser's View Transitions API for page navigation. There is no framer-motion in dependencies (verified in package.json). No spring physics are configured — everything is timing-function based.",

    "duration_ms": {
      "comment": "Durations sourced from app/tailwind.css and app/lib/transitions/transitions.css. The 'base' (200ms) value comes from the dialog content class (`duration-200`).",
      "instant": 0,
      "view_transition": 180,
      "shake": 200,
      "base": 200,
      "fast": 150,
      "slide_out_up": 300,
      "slam": 400
    },

    "easing": {
      "comment": "Cubic-bezier control points for each named curve. ease, ease-in, ease-out, ease-in-out are the CSS defaults Tailwind v4 ships.",
      "linear": "cubic-bezier(0, 0, 1, 1)",
      "ease": "cubic-bezier(0.25, 0.1, 0.25, 1)",
      "ease_in": "cubic-bezier(0.4, 0, 1, 1)",
      "ease_out": "cubic-bezier(0, 0, 0.2, 1)",
      "ease_in_out": "cubic-bezier(0.4, 0, 0.2, 1)"
    },

    "named_animations": {
      "shake": {
        "duration_ms": 200,
        "easing": "ease_in_out",
        "keyframes": "translateX 0 → -5 → +5 → -5 → 0",
        "source": "app/tailwind.css L125, L131-145"
      },
      "slam": {
        "duration_ms": 400,
        "easing": "ease_out",
        "fill_mode": "both",
        "keyframes": "scale 1→1.05→0.98→1.02→1 with letter-spacing pulse",
        "source": "app/tailwind.css L126, L147-173"
      },
      "slide_out_up": {
        "duration_ms": 300,
        "easing": "ease_out",
        "fill_mode": "forwards",
        "keyframes": "translateY 0 → -150% with opacity 1 → 0",
        "source": "app/tailwind.css L127, L175-184"
      },
      "view_transition_root": {
        "duration_ms": 180,
        "easing": "ease_in",
        "fill_mode": "both",
        "comment": "Used by ::view-transition-old(root) and ::view-transition-new(root)",
        "source": "app/lib/transitions/transitions.css L91-105 and app/lib/transitions/view-transition.tsx L199"
      }
    },

    "page_transition_directions": {
      "comment": "View Transitions API names referenced via LinkWithViewTransition. Each maps to one of these keyframes (see app/lib/transitions/transitions.css).",
      "slideLeft": "slide-out-to-left + slide-in-from-right",
      "slideRight": "slide-out-to-right + slide-in-from-left",
      "slideUp": "slide-out-to-top + slide-in-from-bottom",
      "slideDown": "slide-out-to-bottom + slide-in-from-top",
      "fade": "fade-out + fade-in"
    },

    "default_transition_duration_ms": {
      "comment": "Tailwind's `transition-colors` (used on Button, ToastClose, etc.) defaults to 150ms ease (Tailwind v4 default). The dialog uses an explicit duration-200.",
      "value": 150,
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },

  "shadows": {
    "comment": "Tailwind v4 defaults. App uses shadow-xs (cards) and shadow-lg (dialogs, toasts). Note: shadcn v4 components use the v4 name shadow-xs where v3 used shadow-sm.",
    "xs": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "sm": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "inner": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)"
  },

