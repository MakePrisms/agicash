# direnv config — loads the flake's default Rust dev shell automatically
# when the operator `cd ~/agicash`. Override the shell with
# `nix develop .#ios` / `.#android` / `.#wasm` ad-hoc.
use flake

# Load operator-supplied env (gitignored .env) AFTER `use flake`, so any
# value in .env overrides the shellHook defaults. `dotenv_if_exists` uses
# direnv's auto-export semantics (every key is exported), which the
# unprefixed `source .env` from zsh does NOT do.
dotenv_if_exists .env
